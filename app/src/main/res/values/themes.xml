<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Skaitykle" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:windowAnimationStyle">@style/SlideAnimation</item>
    </style>

    <style name="Theme.Skaitykle" parent="Base.Theme.Skaitykle" />
    
    <style name="RoundedCorners" parent="">

        <item name="cornerSize">16dp</item>
        <item name="cornerRadius">15dp</item>
    </style>

    <style name="LargeRoundedCorners" parent="">

        <item name="cornerSize">40dp</item>
        <item name="cornerRadius">40dp</item>
    </style>

    <style name="SlideAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Theme.Skaitykle.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FAFAFA</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/animated_book_loading</item>
        <item name="windowSplashScreenAnimationDuration">2000</item>
        <item name="postSplashScreenTheme">@style/Theme.Skaitykle</item>
    </style>
</resources>